{
  "kind": "collectionType",
  "collectionName": "works",
  "info": {
    "singularName": "work",
    "pluralName": "works",
    "displayName": "Work",
    "description": "摄影作品"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "maxLength": 200
    },
    "year": {
      "type": "string",
      "maxLength": 10
    },
    "location": {
      "type": "string",
      "maxLength": 200
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "width": {
      "type": "integer"
    },
    "height": {
      "type": "integer"
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::category.category"
    },
    "periods": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::period.period",
      "mappedBy": "works"
    }
  }
}
